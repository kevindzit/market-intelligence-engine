# Byte-2-Bite .gitignore
# Python files and folders to ignore

# Bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
.env/
.venv/

# IDE settings
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
*.tmp
*.bak

# Python packaging
build/
dist/
*.egg-info/

# Test and coverage
.coverage
.pytest_cache/
htmlcov/

# Environment variables
*.env

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# MySQL or SQLite databases
*.db
*.sqlite3

archived/
moon-dev-reference/
twikit/
cookies/

my api llm keys.txt

.claudeignore
finance notes for me.txt
strategy-ideas/

cookies/

TWITTER_ACCOUNT_SYSTEM.md
BUG NOTES.txt
pjx.code-workspace

backups/